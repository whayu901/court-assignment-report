# Database Configuration
# For local development, leave DATABASE_URL empty to use SQLite
# For production (Vercel), set DATABASE_URL to your Neon PostgreSQL connection string

# DATABASE_URL=postgresql://user:password@host/database?sslmode=require
# Example for Neon:
# DATABASE_URL=postgresql://neondb_owner:xxxxx@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Server Configuration
PORT=3001
